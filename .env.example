# ============================================================
# LexGraph AI — Environment Configuration
# ============================================================
# Copy this file as .env and fill in your values.

# ---- Neo4j Connection ----
# Download Neo4j Desktop: https://neo4j.com/download/
# Or use AuraDB free tier: https://neo4j.com/cloud/aura-free/
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexgraph2024

# ---- Google Gemini API Key ----
# Get your free API key at: https://aistudio.google.com/apikey
# Without this, AI features use fallback rules (still functional)
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Server ----
PORT=3000
